# Copy this file to .env and fill in your values
# NEVER commit .env to git

PORT=3000
NODE_ENV=development

# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARS

# CTF Flags — only lives on the server, never sent to the browser
FLAG_1=CTF{CYB3R_C4T_QU3ST_H3R0}
FLAG_2=CTF{W1R3_SH4RK_PRO}
FLAG_3=CTF{CRACK_TH3_C0D3}
FLAG_4=CTF{ST3G0_M4ST3R_V4ULT}
FLAG_5=CTF{ULT1MATE_SYS_AD1M1N_2026}
